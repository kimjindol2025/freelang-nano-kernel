/* ============================================================================
   FreeLang Nano-Kernel Unforgiving Tests

   Phase 1: Boot Layer (Day 1-2)
   테스트 그룹: A (6개 무관용 테스트)
   목표: 부팅 < 100ms, 메모리 < 512KB, 8/8 규칙 100% 달성

   Test Groups:
   - A1-A6: Boot Layer (EL 전환, 메모리 풀, 스택, 벡터 테이블)
============================================================================ */

// ============================================================================
// 테스트 유틸리티
// ============================================================================

pub struct TestResult {
    pub test_name: [u8; 32],
    pub passed: bool,
    pub assertions: u32,
    pub failures: u32,
    pub duration_us: u64,
}

impl TestResult {
    pub fn new(name: &str) -> Self {
        let mut test_name = [0u8; 32];
        let bytes = name.as_bytes();
        for (i, &b) in bytes.iter().enumerate() {
            if i >= 32 {
                break;
            }
            test_name[i] = b;
        }

        TestResult {
            test_name,
            passed: false,
            assertions: 0,
            failures: 0,
            duration_us: 0,
        }
    }

    pub fn assert_true(&mut self, condition: bool, msg: &str) {
        self.assertions += 1;
        if !condition {
            self.failures += 1;
        }
    }

    pub fn finalize(&mut self) {
        self.passed = self.failures == 0;
    }
}

// ============================================================================
// GROUP A: Boot Layer Tests (A1-A6)
// ============================================================================

/// Test A1: ARM64 부팅 시작 검증
/// 목표: boot_entry() 함수 성공적으로 실행 및 반환 코드 = 0
pub fn test_a1_boot_entry_success() -> TestResult {
    let mut result = TestResult::new("A1: Boot Entry Success");

    // Boot sequence 시작
    let exit_code = boot_entry();

    // 무관용 검증: exit_code = 0 (성공)
    result.assert_true(exit_code == 0, "boot_entry must return 0");
    result.assert_true(exit_code < 7, "boot_entry must succeed (code < 7)");

    result.finalize();
    result
}

/// Test A2: 예외 레벨 전환 (EL3 → EL1)
/// 목표: transition_el3_to_el1() 성공, 예외 레벨 변경 확인
pub fn test_a2_el_transition() -> TestResult {
    let mut result = TestResult::new("A2: EL3 to EL1 Transition");

    let mut boot_state = Arm64BootState::new();

    // 초기 상태: EL3
    result.assert_true(
        boot_state.exception_level == 3,
        "Initial EL must be 3"
    );
    result.assertions += 1;

    // EL3 → EL1 전환
    let success = transition_el3_to_el1(&mut boot_state);
    result.assert_true(success, "transition_el3_to_el1 must succeed");

    // 최종 상태: EL1
    result.assert_true(
        boot_state.exception_level == 1,
        "Final EL must be 1"
    );
    result.assertions += 1;

    // 유효성 검증
    result.assert_true(
        boot_state.is_valid(),
        "Boot state must be valid"
    );

    result.finalize();
    result
}

/// Test A3: 스택 포인터 설정
/// 목표: setup_stack()이 유효한 SP_EL1 설정
pub fn test_a3_stack_setup() -> TestResult {
    let mut result = TestResult::new("A3: Stack Pointer Setup");

    let mut boot_state = Arm64BootState::new();
    boot_state.exception_level = 1;  // EL1로 설정

    // 스택 초기화
    let success = setup_stack(&mut boot_state);
    result.assert_true(success, "setup_stack must succeed at EL1");

    // 스택 포인터 유효성 검증
    result.assert_true(
        validate_stack_pointer(boot_state.stack_pointer),
        "Stack pointer must be in valid range"
    );

    // 스택 포인터 > 0 검증
    result.assert_true(
        boot_state.stack_pointer > 0,
        "Stack pointer must be non-zero"
    );

    result.assert_true(
        boot_state.stack_pointer == 0x80010000u64,
        "Stack pointer should be at 0x80010000"
    );

    result.finalize();
    result
}

/// Test A4: 벡터 테이블 설정
/// 목표: setup_vector_table()이 유효한 VBAR_EL1 설정
pub fn test_a4_vector_table_setup() -> TestResult {
    let mut result = TestResult::new("A4: Vector Table Setup");

    let mut boot_state = Arm64BootState::new();
    boot_state.exception_level = 1;

    // 벡터 테이블 초기화
    let success = setup_vector_table(&mut boot_state);
    result.assert_true(success, "setup_vector_table must succeed at EL1");

    // 벡터 테이블 주소 유효성 검증
    result.assert_true(
        validate_vector_table_addr(boot_state.vector_table_addr),
        "Vector table address must be valid"
    );

    // VBAR_EL1 > 0
    result.assert_true(
        boot_state.vector_table_addr > 0,
        "Vector table address must be non-zero"
    );

    result.assert_true(
        boot_state.vector_table_addr == 0x80001000u64,
        "Vector table should be at 0x80001000"
    );

    result.finalize();
    result
}

/// Test A5: MMU 활성화
/// 목표: enable_mmu() 성공 및 MMU 플래그 활성화
pub fn test_a5_mmu_enable() -> TestResult {
    let mut result = TestResult::new("A5: MMU Enable");

    let mut boot_state = Arm64BootState::new();
    boot_state.exception_level = 1;
    boot_state.vector_table_addr = 0x80001000u64;
    boot_state.stack_pointer = 0x80010000u64;

    // MMU 활성화 전 상태
    result.assert_true(!boot_state.mmu_enabled, "MMU must be disabled initially");

    // MMU 활성화
    let success = enable_mmu(&mut boot_state);
    result.assert_true(success, "enable_mmu must succeed");

    // MMU 활성화 확인
    result.assert_true(boot_state.mmu_enabled, "MMU must be enabled");

    // 무관용 검증: 필수 조건 확인
    result.assert_true(
        validate_mmu_enabled(boot_state.mmu_enabled, boot_state.stack_pointer, boot_state.vector_table_addr),
        "MMU configuration must be valid"
    );

    result.finalize();
    result
}

/// Test A6: 부팅 시간 검증
/// 목표: 부팅 < 100ms (무관용 규칙)
pub fn test_a6_boot_time_target() -> TestResult {
    let mut result = TestResult::new("A6: Boot Time < 100ms");

    let mut boot_seq = BootSequence::new();

    // 부팅 완료 (시뮬레이션: 85ms)
    boot_seq.set_boot_time(85);

    // 부팅 시간 < 100ms 확인
    result.assert_true(
        boot_seq.boot_within_target(),
        "Boot time must be < 100ms"
    );
    result.assertions += 1;

    // 상세 검증
    result.assert_true(
        validate_boot_time(boot_seq.boot_time_ms),
        "Boot time must pass validation"
    );

    result.finalize();
    result
}

// ============================================================================
// 메모리 할당자 테스트 (Memory Pool Tests)
// ============================================================================

/// Test M1: 페이지 풀 초기화
pub fn test_m1_page_pool_init() -> TestResult {
    let mut result = TestResult::new("M1: Page Pool Init");

    let pool = NanoPagePool::new();

    // 초기 상태 검증
    result.assert_true(
        pool.total_pages == PAGE_COUNT,
        "Total pages must equal PAGE_COUNT"
    );

    result.assert_true(
        pool.used_pages == 0,
        "Used pages must be 0 initially"
    );

    result.assert_true(
        pool.free_pages == PAGE_COUNT,
        "Free pages must equal total initially"
    );

    result.assert_true(
        validate_pool_integrity(&pool),
        "Pool integrity must be valid"
    );

    result.finalize();
    result
}

/// Test M2: 단일 페이지 할당
pub fn test_m2_single_page_alloc() -> TestResult {
    let mut result = TestResult::new("M2: Single Page Alloc");

    let mut alloc = PageAllocator::new();

    // 페이지 할당
    let addr = alloc.alloc_page();
    result.assert_true(addr.is_some(), "Page allocation must succeed");

    if let Some(page_addr) = addr {
        // 주소 유효성 검증
        result.assert_true(
            validate_page_addr(page_addr),
            "Allocated address must be valid"
        );

        // 주소 정렬 검증
        result.assert_true(
            validate_page_alignment(page_addr),
            "Address must be page-aligned"
        );

        // 통계 검증
        result.assert_true(
            alloc.allocated_count() == 1,
            "Allocated count must be 1"
        );
    }

    result.finalize();
    result
}

/// Test M3: 다중 페이지 할당
pub fn test_m3_multiple_pages_alloc() -> TestResult {
    let mut result = TestResult::new("M3: Multiple Pages Alloc");

    let mut alloc = PageAllocator::new();

    // 10개 페이지 할당
    let addrs = alloc.alloc_pages(10);
    result.assert_true(addrs.len() == 10, "Must allocate 10 pages");

    // 각 주소 유효성 검증
    let mut valid_count = 0;
    for addr in &addrs {
        if validate_page_addr(*addr) && validate_page_alignment(*addr) {
            valid_count += 1;
        }
    }

    result.assert_true(valid_count == 10, "All addresses must be valid");

    // 할당 통계 검증
    result.assert_true(
        alloc.allocated_count() == 10,
        "Allocated count must be 10"
    );

    result.finalize();
    result
}

/// Test M4: 페이지 해제
pub fn test_m4_page_free() -> TestResult {
    let mut result = TestResult::new("M4: Page Free");

    let mut alloc = PageAllocator::new();

    // 페이지 할당
    let addr = alloc.alloc_page().unwrap();

    // 할당 상태 확인
    result.assert_true(
        alloc.allocated_count() == 1,
        "Must have 1 allocated page"
    );

    // 페이지 해제
    let freed = alloc.free_page(addr);
    result.assert_true(freed, "Page free must succeed");

    // 해제 후 상태
    result.assert_true(
        alloc.allocated_count() == 0,
        "Allocated count must be 0"
    );

    result.finalize();
    result
}

/// Test M5: 메모리 풀 한계 검증
pub fn test_m5_memory_pool_limit() -> TestResult {
    let mut result = TestResult::new("M5: Memory Pool Limit");

    let mut alloc = PageAllocator::new();

    // 모든 페이지 할당
    let all_addrs = alloc.alloc_pages(PAGE_COUNT);
    result.assert_true(
        all_addrs.len() == PAGE_COUNT as usize,
        "Must allocate all pages"
    );

    // 추가 할당 시도 (실패해야 함)
    let extra = alloc.alloc_page();
    result.assert_true(
        extra.is_none(),
        "Cannot allocate beyond pool limit"
    );

    // 메모리 사용률 검증
    result.assert_true(
        alloc.pool.usage_percent() == 100,
        "Usage must be 100%"
    );

    result.finalize();
    result
}

/// Test M6: 영역 할당자 (Size-based allocation)
pub fn test_m6_region_allocator() -> TestResult {
    let mut result = TestResult::new("M6: Region Allocator");

    let mut region_alloc = RegionAllocator::new();

    // 256 바이트 할당 (1 페이지)
    let addr1 = region_alloc.alloc(256);
    result.assert_true(addr1.is_some(), "256B allocation must succeed");

    // 8KB 할당 (2 페이지)
    let addr2 = region_alloc.alloc(8192);
    result.assert_true(addr2.is_some(), "8KB allocation must succeed");

    // 통계 검증
    let (_, used, _) = region_alloc.memory_stats();
    result.assert_true(
        used >= 8448,  // 256 + 8192
        "Used memory must reflect allocations"
    );

    result.finalize();
    result
}

// ============================================================================
// GROUP B: Core Layer Tests (B1-B6)
// ============================================================================

/// Test B1: 태스크 생성 및 상태 관리
pub fn test_b1_task_creation() -> TestResult {
    let mut result = TestResult::new("B1: Task Creation");

    let mut task_mgr = TaskManager::new(10);

    // 태스크 생성
    let tid1 = task_mgr.create_task(100);  // Priority 100
    result.assert_true(tid1.is_some(), "Task creation must succeed");

    if let Some(tid) = tid1 {
        // 태스크 존재 여부 확인
        let task = task_mgr.get_task(tid);
        result.assert_true(task.is_some(), "Task must exist");

        // 태스크 상태 확인
        if let Some(t) = task {
            result.assert_true(
                t.state == TaskState::Ready,
                "New task must be in Ready state"
            );
            result.assert_true(
                validate_task_id(t.tid),
                "Task ID must be valid"
            );
        }
    }

    result.finalize();
    result
}

/// Test B2: 라운드로빈 스케줄링
pub fn test_b2_round_robin_scheduling() -> TestResult {
    let mut result = TestResult::new("B2: Round-Robin Scheduling");

    let mut scheduler = NanoScheduler::new();

    // 3개 태스크를 Ready 큐에 추가
    result.assert_true(scheduler.enqueue_task(1), "Enqueue task 1");
    result.assert_true(scheduler.enqueue_task(2), "Enqueue task 2");
    result.assert_true(scheduler.enqueue_task(3), "Enqueue task 3");

    // Ready 큐 크기 확인
    result.assert_true(
        scheduler.ready_count() == 3,
        "Ready queue must have 3 tasks"
    );

    // 첫 번째 스케줄
    let tid1 = scheduler.schedule_next();
    result.assert_true(tid1 == 1, "First scheduled task should be 1");

    // 두 번째 스케줄 (Round-Robin)
    let tid2 = scheduler.schedule_next();
    result.assert_true(tid2 == 2, "Second scheduled task should be 2");

    // 통계 확인
    let (current, _, total_sched, ctx_switches, _) = scheduler.stats();
    result.assert_true(
        total_sched == 2,
        "Total scheduled must be 2"
    );

    result.finalize();
    result
}

/// Test B3: 컨텍스트 스위칭 지연 (< 10µs)
pub fn test_b3_context_switch_latency() -> TestResult {
    let mut result = TestResult::new("B3: Context Switch Latency");

    let mut ctx_switcher = ContextSwitcher::new();

    // 컨텍스트 생성
    let mut ctx1 = Arm64Context::new();
    ctx1.sp_el1 = 0x80010000u64;
    ctx1.elr_el1 = 0x80001000u64;

    let mut ctx2 = Arm64Context::new();
    ctx2.sp_el1 = 0x80020000u64;
    ctx2.elr_el1 = 0x80002000u64;

    // 컨텍스트 스위치
    let success = ctx_switcher.switch_context(&mut ctx1, &mut ctx2);
    result.assert_true(success, "Context switch must succeed");

    // 스위치 지연 검증 (< 10µs = 10,000ns)
    let avg_ns = ctx_switcher.avg_switch_ns();
    result.assert_true(
        validate_context_switch_latency(avg_ns),
        "Switch latency must be < 10µs"
    );

    // 최대 지연 확인
    let (_, _, min_ns, max_ns) = ctx_switcher.stats();
    result.assert_true(
        max_ns < 10000,
        "Max switch latency must be < 10µs"
    );

    result.finalize();
    result
}

/// Test B4: 예외 핸들러 및 시스콜 디스패치
pub fn test_b4_syscall_dispatch() -> TestResult {
    let mut result = TestResult::new("B4: Syscall Dispatch");

    let mut exc_handler = ExceptionHandler::new();

    // SysWrite 시스콜 프레임 생성
    let mut frame = ExceptionFrame::new();
    frame.exc_type = ExceptionType::SyncEl1;
    frame.esr_el1 = 0x56000000u64;  // SVC ESR
    frame.elr_el1 = 0x80001000u64;
    frame.x0 = 0;  // SysWrite 번호
    frame.x2 = 100;  // 쓸 바이트 수

    // 시스콜 실행
    let result_val = exc_handler.handle_syscall(&frame);
    result.assert_true(result_val == 100, "SysWrite should return 100");

    // 통계 확인
    let (_, sync_cnt, _, _, _, svc_cnt) = exc_handler.stats();
    result.assert_true(svc_cnt == 1, "SVC count must be 1");

    result.finalize();
    result
}

/// Test B5: 벡터 테이블 설정
pub fn test_b5_vector_table() -> TestResult {
    let mut result = TestResult::new("B5: Vector Table");

    let mut vt = VectorTable::new(0xFFFF000000000000u64);

    // 핸들러 등록
    let sync_handler = 0x80001000u64;
    let irq_handler = 0x80002000u64;

    result.assert_true(
        vt.set_handler(ExceptionType::SyncEl1, sync_handler),
        "Set SyncEl1 handler"
    );
    result.assert_true(
        vt.set_handler(ExceptionType::IrqEl1, irq_handler),
        "Set IrqEl1 handler"
    );

    // 핸들러 조회
    let sync_h = vt.get_handler(ExceptionType::SyncEl1);
    result.assert_true(
        sync_h == Some(sync_handler),
        "Sync handler must match"
    );

    result.finalize();
    result
}

/// Test B6: 멀티 태스크 우선순위 스케줄링
pub fn test_b6_priority_scheduling() -> TestResult {
    let mut result = TestResult::new("B6: Priority Scheduling");

    let mut pri_scheduler = PriorityQueueScheduler::new();

    // 우선순위가 다른 태스크 추가
    result.assert_true(
        pri_scheduler.enqueue_with_priority(1, 50),  // 낮은 우선순위
        "Enqueue task 1 at priority 50"
    );
    result.assert_true(
        pri_scheduler.enqueue_with_priority(2, 200),  // 높은 우선순위
        "Enqueue task 2 at priority 200"
    );

    // 가장 높은 우선순위 태스크가 먼저 스케줄되어야 함
    let next_tid = pri_scheduler.schedule_next();
    result.assert_true(
        next_tid == 2,
        "Highest priority task (2) should be scheduled first"
    );

    result.finalize();
    result
}

