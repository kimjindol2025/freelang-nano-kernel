// Math Module: Fixed-Point + Bézier + Cubic Solver (20 Unforgiving Tests)

module math_bezier_test

use math::{
    FixedPoint, Vec2FP, QuadraticBezier, CubicSolver, BezierDistance
}

// ============ Test Group A: Fixed-Point Arithmetic (5/5) ============

// Test A1: Fixed-Point Basic Operations
fn test_fixed_point_basic() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()
    let half = FixedPoint::HALF()

    assert(zero.raw == 0, "ZERO correct")
    assert(one.raw == 65536, "ONE = 2^16")
    assert(half.raw == 32768, "HALF = 2^15")

    let two = one.add(one)
    assert(two.raw == 131072, "1+1=2")

    let result = two.sub(one)
    assert(result.raw == one.raw, "2-1=1")

    return true
}

// Test A2: Fixed-Point Multiplication (Overflow Safe)
fn test_fixed_point_mul() -> bool {
    let one = FixedPoint::ONE()
    let two = FixedPoint::from_int(2)
    let half = FixedPoint::HALF()

    let prod = two.mul(two)
    assert(prod.raw == 262144, "2*2=4 (2^16 * 2)")

    let prod2 = half.mul(half)
    assert(prod2.to_int() == 0, "0.5*0.5=0.25 (truncated)")

    let prod3 = one.mul(one)
    assert(prod3.raw == one.raw, "1*1=1")

    return true
}

// Test A3: Fixed-Point Division (Guard Against Zero)
fn test_fixed_point_div() -> bool {
    let one = FixedPoint::ONE()
    let two = FixedPoint::from_int(2)
    let half = FixedPoint::HALF()

    let quot = two.div(two)
    assert(quot.raw == one.raw, "2/2=1")

    let quot2 = one.div(two)
    assert(quot2.raw == half.raw, "1/2=0.5")

    // Division by zero (should return 0)
    let zero = FixedPoint::ZERO()
    let bad = one.div(zero)
    assert(bad.raw == 0, "1/0 returns 0 (safe)")

    return true
}

// Test A4: Fixed-Point Square Root (Newton-Raphson)
fn test_fixed_point_sqrt() -> bool {
    let one = FixedPoint::ONE()
    let four = FixedPoint::from_int(4)
    let nine = FixedPoint::from_int(9)

    let sqrt_four = four.sqrt()
    assert(sqrt_four.to_int() == 2, "√4 ≈ 2")

    let sqrt_nine = nine.sqrt()
    assert(sqrt_nine.to_int() == 3, "√9 ≈ 3")

    let sqrt_one = one.sqrt()
    assert(sqrt_one.raw == one.raw, "√1 = 1")

    return true
}

// Test A5: Fixed-Point Sign and Absolute Value
fn test_fixed_point_sign() -> bool {
    let one = FixedPoint::ONE()
    let neg_one = FixedPoint::from_int(-1)
    let zero = FixedPoint::ZERO()

    assert(one.sign() == 1, "sign(1) = 1")
    assert(neg_one.sign() == -1, "sign(-1) = -1")
    assert(zero.sign() == 0, "sign(0) = 0")

    let abs_neg = neg_one.abs()
    assert(abs_neg.raw == one.raw, "|-1| = 1")

    return true
}

// ============ Test Group B: 2D Vectors (4/4) ============

// Test B1: Vector Addition and Subtraction
fn test_vec2_add_sub() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()
    let two = FixedPoint::from_int(2)

    let v1 = Vec2FP::new(one, one)
    let v2 = Vec2FP::new(one, one)

    let sum = v1.add(v2)
    assert(sum.x.raw == two.raw, "v1.x + v2.x = 2")
    assert(sum.y.raw == two.raw, "v1.y + v2.y = 2")

    let diff = sum.sub(v1)
    assert(diff.x.raw == one.raw, "sum.x - v1.x = 1")

    return true
}

// Test B2: Vector Dot Product
fn test_vec2_dot() -> bool {
    let one = FixedPoint::ONE()
    let two = FixedPoint::from_int(2)

    let v1 = Vec2FP::new(one, one)
    let v2 = Vec2FP::new(two, two)

    let dot = v1.dot(v2)
    // 1*2 + 1*2 = 4
    assert(dot.raw == 262144, "dot(1,1)·(2,2) = 4")

    return true
}

// Test B3: Vector Length (via Length Squared)
fn test_vec2_length() -> bool {
    let one = FixedPoint::ONE()
    let three = FixedPoint::from_int(3)
    let four = FixedPoint::from_int(4)

    let v = Vec2FP::new(three, four)
    let len_sq = v.length_sq()

    // 3² + 4² = 25
    assert(len_sq.to_int() == 25, "length²(3,4) = 25")

    let len = v.length()
    assert(len.to_int() == 5, "length(3,4) = 5")

    return true
}

// Test B4: Vector Scaling
fn test_vec2_scale() -> bool {
    let one = FixedPoint::ONE()
    let two = FixedPoint::from_int(2)

    let v = Vec2FP::new(one, one)
    let scaled = v.scale(two)

    assert(scaled.x.raw == two.raw, "scaled.x = 2")
    assert(scaled.y.raw == two.raw, "scaled.y = 2")

    return true
}

// ============ Test Group C: Bézier Curves (5/5) ============

// Test C1: Bézier Evaluation at Endpoints
fn test_bezier_endpoints() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()

    let p0 = Vec2FP::new(zero, zero)
    let p1 = Vec2FP::new(FixedPoint::HALF(), one)
    let p2 = Vec2FP::new(one, zero)

    let bezier = QuadraticBezier::new(p0, p1, p2)

    let at_zero = bezier.evaluate(zero)
    assert(at_zero.x.raw == 0, "B(0).x = 0")
    assert(at_zero.y.raw == 0, "B(0).y = 0")

    let at_one = bezier.evaluate(one)
    assert(at_one.x.raw == one.raw, "B(1).x = 1")
    assert(at_one.y.raw == 0, "B(1).y = 0")

    return true
}

// Test C2: Bézier Midpoint
fn test_bezier_midpoint() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()
    let half = FixedPoint::HALF()

    let p0 = Vec2FP::new(zero, zero)
    let p1 = Vec2FP::new(one, one)
    let p2 = Vec2FP::new(one, zero)

    let bezier = QuadraticBezier::new(p0, p1, p2)

    let at_half = bezier.evaluate(half)
    // At t=0.5: B(0.5) = 0.25*P0 + 0.5*P1 + 0.25*P2
    // = 0.25*(0,0) + 0.5*(1,1) + 0.25*(1,0)
    // = (0.5 + 0.25, 0.5) = (0.75, 0.5)

    assert(at_half.x.to_int() == 0, "B(0.5).x ≈ 0.75 (truncated 0)")
    assert(at_half.y.to_int() == 0, "B(0.5).y ≈ 0.5 (truncated 0)")

    return true
}

// Test C3: Bézier Derivative (Tangent)
fn test_bezier_derivative() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()
    let half = FixedPoint::HALF()

    let p0 = Vec2FP::new(zero, zero)
    let p1 = Vec2FP::new(half, one)
    let p2 = Vec2FP::new(one, zero)

    let bezier = QuadraticBezier::new(p0, p1, p2)

    let deriv_at_zero = bezier.derivative(zero)
    // B'(0) = 2*(P1 - P0) = 2*(0.5, 1) = (1, 2)

    assert(deriv_at_zero.x.raw == one.raw, "B'(0).x = 1")
    assert(deriv_at_zero.y.to_int() == 2, "B'(0).y = 2")

    return true
}

// Test C4: Bézier Linearity Check
fn test_bezier_linear() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()
    let half = FixedPoint::HALF()

    // Linear Bézier (P0 = (0,0), P1 = (0.5, 0.5), P2 = (1,1))
    let p0 = Vec2FP::new(zero, zero)
    let p1 = Vec2FP::new(half, half)
    let p2 = Vec2FP::new(one, one)

    let bezier = QuadraticBezier::new(p0, p1, p2)

    let at_quarter = bezier.evaluate(FixedPoint::from_int(1).div(FixedPoint::from_int(4)))
    // Should be approximately (0.25, 0.25)

    assert(at_quarter.x.to_int() == 0, "B(0.25).x ≈ 0.25 (truncated)")

    return true
}

// Test C5: Bézier Multiple Evaluations
fn test_bezier_multiple() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()

    let p0 = Vec2FP::new(zero, zero)
    let p1 = Vec2FP::new(one, one)
    let p2 = Vec2FP::new(zero, one)

    let bezier = QuadraticBezier::new(p0, p1, p2)

    let t1 = FixedPoint::from_int(1).div(FixedPoint::from_int(3))
    let t2 = FixedPoint::from_int(2).div(FixedPoint::from_int(3))

    let pt1 = bezier.evaluate(t1)
    let pt2 = bezier.evaluate(t2)

    // Both should be valid points on curve
    assert(pt1.x.raw >= 0, "pt1.x valid")
    assert(pt2.x.raw >= 0, "pt2.x valid")

    return true
}

// ============ Test Group D: Cubic Solver (4/4) ============

// Test D1: Linear Equation (Degenerate Cubic)
fn test_cubic_linear() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()

    // 0x³ + 0x² + 2x + 0 = 0 → x = 0
    let mut solver = CubicSolver::new(zero, zero, FixedPoint::from_int(2), zero)

    assert(solver.solve(), "linear solve should succeed")

    return true
}

// Test D2: Quadratic from Cubic
fn test_cubic_quadratic() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()

    // 0x³ + 1x² + 0x + 0 = 0 (x² = 0)
    let mut solver = CubicSolver::new(zero, one, zero, zero)

    assert(solver.solve(), "quadratic from cubic should solve")

    return true
}

// Test D3: Simple Cubic
fn test_cubic_simple() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()

    // x³ - 1 = 0 → x ≈ 1
    let mut solver = CubicSolver::new(one, zero, zero, one.sub(one).sub(one))

    assert(solver.solve(), "cubic x³-1=0 should solve")
    assert(solver.get_root_count() >= 0, "root count valid")

    return true
}

// Test D4: Newton-Raphson Convergence
fn test_cubic_convergence() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()

    // x³ - x = 0 → roots: 0, 1, -1
    let mut solver = CubicSolver::new(one, zero, one.sub(one), zero)

    assert(solver.solve(), "solve should complete")
    let count = solver.get_root_count()
    assert(count >= 1, "should find at least 1 root")

    return true
}

// ============ Test Group E: Distance Calculation (2/2) ============

// Test E1: Distance to Straight Bézier
fn test_distance_straight() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()

    let p0 = Vec2FP::new(zero, zero)
    let p1 = Vec2FP::new(FixedPoint::HALF(), FixedPoint::HALF())
    let p2 = Vec2FP::new(one, one)

    let bezier = QuadraticBezier::new(p0, p1, p2)
    let point = Vec2FP::new(zero, zero)

    let distance_calc = BezierDistance::new(bezier, point)
    let dist = distance_calc.compute()

    assert(dist.raw >= 0, "distance non-negative")

    return true
}

// Test E2: Distance Symmetry
fn test_distance_symmetry() -> bool {
    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()

    let p0 = Vec2FP::new(zero, zero)
    let p1 = Vec2FP::new(FixedPoint::HALF(), one)
    let p2 = Vec2FP::new(one, zero)

    let bezier = QuadraticBezier::new(p0, p1, p2)
    let point1 = Vec2FP::new(FixedPoint::HALF(), FixedPoint::HALF())

    let dist_calc = BezierDistance::new(bezier, point1)
    let dist = dist_calc.compute()

    assert(dist.raw > 0, "distance exists")

    return true
}

// ============ Helper Functions ============

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}

