// Font Renderer Tests: Complete Text Rendering Pipeline (19 Unforgiving Tests)

module font_renderer_test

use font_renderer::{
    GlyphCache, FontMetrics, TextLayout, FontRenderer, TextBuffer
}

use math::{
    FixedPoint, Vec2FP
}

// ============ Test Group A: Glyph Cache (3/3) ============

// Test A1: Cache Creation and Basic Operations
fn test_glyph_cache_creation() -> bool {
    let mut cache = GlyphCache::new()

    assert(cache.count == 0, "initial count 0")
    assert(cache.total_hits == 0, "initial hits 0")
    assert(cache.total_misses == 0, "initial misses 0")
    assert(cache.max_size == 512, "max size 512")

    return true
}

// Test A2: Cache Add and Lookup
fn test_glyph_cache_operations() -> bool {
    let mut cache = GlyphCache::new()

    let bitmap1 = Bitmap::new(64, 64)
    assert(cache.add(1, bitmap1), "add glyph 1")
    assert(cache.count == 1, "count 1")
    assert(cache.contains(1), "contains glyph 1")

    let bitmap2 = Bitmap::new(64, 64)
    assert(cache.add(2, bitmap2), "add glyph 2")
    assert(cache.count == 2, "count 2")
    assert(cache.contains(2), "contains glyph 2")

    // Missing glyph
    assert(!cache.contains(99), "not contains 99")

    return true
}

// Test A3: Cache Hit Rate
fn test_glyph_cache_hit_rate() -> bool {
    let mut cache = GlyphCache::new()

    let bitmap = Bitmap::new(64, 64)
    assert(cache.add(1, bitmap), "add glyph")

    // Hit
    let _ = cache.get(1)
    assert(cache.total_hits == 1, "hits 1")

    // Miss
    let _ = cache.get(99)
    assert(cache.total_misses == 1, "misses 1")

    let rate = cache.hit_rate()
    assert(rate.raw > 0, "hit rate > 0")

    return true
}

// ============ Test Group B: Font Metrics (3/3) ============

// Test B1: Metrics Creation
fn test_font_metrics_creation() -> bool {
    let metrics = FontMetrics::new("Arial")

    assert(metrics.font_name == "Arial", "name Arial")
    assert(metrics.units_per_em == 2048, "units 2048")
    assert(metrics.ascender > 0, "ascender > 0")
    assert(metrics.descender < 0, "descender < 0")

    return true
}

// Test B2: Metrics Validation and Properties
fn test_font_metrics_validation() -> bool {
    let metrics = FontMetrics::new("TestFont")

    assert(metrics.validate(), "metrics valid")
    assert(metrics.x_height > 0, "x_height > 0")
    assert(metrics.cap_height > 0, "cap_height > 0")

    let line_h = metrics.line_height()
    assert(line_h > 0, "line height > 0")
    assert(line_h == metrics.ascender - metrics.descender + metrics.line_gap, "height calc")

    return true
}

// Test B3: Pixel Scaling
fn test_font_metrics_scaling() -> bool {
    let metrics = FontMetrics::new("Test")

    let scale_12 = metrics.scale_to_pixels(12)
    assert(scale_12.raw > 0, "12pt scale > 0")

    let scale_24 = metrics.scale_to_pixels(24)
    assert(scale_24.raw > scale_12.raw, "24pt > 12pt")
    assert(scale_24.raw == scale_12.raw * 2, "linear scaling")

    return true
}

// ============ Test Group C: Text Layout (4/4) ============

// Test C1: Layout Creation and Glyph Addition
fn test_text_layout_creation() -> bool {
    let mut layout = TextLayout::new()

    assert(layout.run_count == 0, "initial count 0")
    assert(layout.total_width == 0, "initial width 0")

    assert(layout.add_glyph(1, 100), "add glyph 1")
    assert(layout.run_count == 1, "count 1")
    assert(layout.total_width == 100, "width 100")

    return true
}

// Test C2: Multiple Glyphs and Advance
fn test_text_layout_glyphs() -> bool {
    let mut layout = TextLayout::new()

    assert(layout.add_glyph(1, 80), "add glyph 1 (80)")
    assert(layout.add_glyph(2, 90), "add glyph 2 (90)")
    assert(layout.add_glyph(3, 85), "add glyph 3 (85)")

    assert(layout.run_count == 3, "count 3")
    assert(layout.total_width == 255, "width 80+90+85=255")

    return true
}

// Test C3: Kerning Adjustment
fn test_text_layout_kerning() -> bool {
    let mut layout = TextLayout::new()

    assert(layout.add_glyph(1, 100), "add glyph 1")
    assert(layout.total_width == 100, "width 100")

    assert(layout.add_kerning(-10), "kerning -10")
    assert(layout.total_width == 90, "width 90 (100-10)")

    assert(layout.add_glyph(2, 100), "add glyph 2")
    assert(layout.total_width == 190, "width 190")

    return true
}

// Test C4: Line Wrapping
fn test_text_layout_wrap() -> bool {
    let mut layout = TextLayout::new()

    // Add 5 glyphs, each 100 wide
    for i in 0..5 {
        let id = (i + 1) as u16
        assert(layout.add_glyph(id, 100), "add glyph")
    }

    assert(layout.total_width == 500, "width 500")

    // Wrap at 250 pixels
    let line_count = layout.line_wrap(250)
    assert(line_count >= 2, "line count >= 2")
    assert(layout.total_height > 0, "height > 0")

    return true
}

// ============ Test Group D: Font Renderer (4/4) ============

// Test D1: Renderer Creation
fn test_font_renderer_creation() -> bool {
    let renderer = FontRenderer::new("TestFont")

    assert(renderer.current_size == 12, "default size 12")
    assert(renderer.metrics.font_name == "TestFont", "name set")

    return true
}

// Test D2: Font Size and Quality
fn test_font_renderer_config() -> bool {
    let mut renderer = FontRenderer::new("Test")

    assert(renderer.set_font_size(16), "set size 16")
    assert(renderer.current_size == 16, "size 16")

    assert(renderer.set_font_size(24), "set size 24")
    assert(renderer.current_size == 24, "size 24")

    assert(!renderer.set_font_size(0), "size 0 fails")
    assert(!renderer.set_font_size(300), "size 300 fails")

    assert(renderer.set_quality(0), "quality 0")
    assert(renderer.set_quality(3), "quality 3")

    return true
}

// Test D3: Font Loading
fn test_font_renderer_load() -> bool {
    let mut renderer = FontRenderer::new("Arial")

    assert(renderer.load_font(true), "load valid font")
    assert(!renderer.load_font(false), "load invalid font")

    return true
}

// Test D4: Cache Statistics
fn test_font_renderer_cache_stats() -> bool {
    let renderer = FontRenderer::new("Test")

    let stats = renderer.get_cache_stats()
    assert(stats.len() > 0, "stats string exists")

    let info = renderer.font_info()
    assert(info.len() > 0, "info string exists")
    assert(info.contains("Test"), "info contains font name")

    return true
}

// ============ Test Group E: Text Buffer (3/3) ============

// Test E1: Buffer Creation
fn test_text_buffer_creation() -> bool {
    let buffer = TextBuffer::new()

    assert(buffer.glyph_count == 0, "initial count 0")
    assert(buffer.get_glyph_count() == 0, "get count 0")

    return true
}

// Test E2: Buffer Add Glyphs
fn test_text_buffer_add_glyphs() -> bool {
    let mut buffer = TextBuffer::new()

    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()
    let two = FixedPoint::from_int(2)

    assert(buffer.add_glyph(1, zero, zero), "add at (0,0)")
    assert(buffer.get_glyph_count() == 1, "count 1")

    assert(buffer.add_glyph(2, one, zero), "add at (1,0)")
    assert(buffer.get_glyph_count() == 2, "count 2")

    assert(buffer.add_glyph(3, two, one), "add at (2,1)")
    assert(buffer.get_glyph_count() == 3, "count 3")

    return true
}

// Test E3: Buffer Clear
fn test_text_buffer_clear() -> bool {
    let mut buffer = TextBuffer::new()

    let zero = FixedPoint::ZERO()

    assert(buffer.add_glyph(1, zero, zero), "add glyph")
    assert(buffer.get_glyph_count() == 1, "count 1")

    assert(buffer.clear(), "clear")
    assert(buffer.glyph_count == 0, "count 0")
    assert(buffer.get_glyph_count() == 0, "get count 0")

    return true
}

// ============ Integration Tests ============

// Test F1: Complete Text Rendering Pipeline
fn test_complete_rendering_pipeline() -> bool {
    let mut renderer = FontRenderer::new("CompleteTest")

    // Step 1: Setup
    assert(renderer.set_font_size(14), "set size")
    assert(renderer.set_quality(1), "set quality")

    // Step 2: Load font
    assert(renderer.load_font(true), "load font")

    // Step 3: Layout text
    let layout = renderer.layout_text("Hello")
    assert(layout.run_count > 0, "layout has glyphs")
    assert(layout.total_width > 0, "layout has width")

    // Step 4: Measure text
    let measured = renderer.measure_text(300)
    assert(measured.get_run_count() > 0, "measured has glyphs")

    return true
}

// Test F2: Multi-Size Rendering
fn test_multi_size_rendering() -> bool {
    let mut renderer = FontRenderer::new("MultiSize")

    // Test multiple font sizes
    for size in 10..26 {
        assert(renderer.set_font_size(size), "set size")
        assert(renderer.current_size == size, "size matches")
    }

    return true
}

