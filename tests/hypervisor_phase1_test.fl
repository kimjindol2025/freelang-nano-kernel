// Hypervisor Phase 1: Stage 2 MMU Tests (10 Unforgiving Tests)

module hypervisor_phase1_test

use hypervisor::{
    VTTBR, TranslationGranule, Stage2PTE, Stage2PageTable, GuestAddressSpace
}

use vttbr::{
    VTTBRRegister, VTTBRPool, VTTBRContextSwitch
}

use guest_memory::{
    GuestMemoryRegion, GuestMemoryAllocator, MemoryAccessAudit
}

// ============ Test Group A: VTTBR Register (4/4) ============

// Test A1: VTTBR Initialization & Validation
fn test_vttbr_init() -> bool {
    let vttbr = VTTBR::new(1, 0x80000000)

    assert(vttbr.validate(), "VTTBR should validate")
    assert(vttbr.get_vmid() == 1, "VMID should be 1")
    assert(vttbr.get_base_address() == 0x80000000, "base should be 0x80000000")

    let reg_val = vttbr.to_register_value()
    assert(reg_val != 0, "register value should be non-zero")

    return true
}

// Test A2: VTTBR Hardware Register Loading
fn test_vttbr_register_load() -> bool {
    let mut reg = VTTBRRegister::new()

    let vttbr = VTTBR::new(2, 0x81000000)
    assert(reg.load_vttbr(vttbr), "load should succeed")

    assert(reg.is_configured(), "register should be configured")
    assert(reg.get_current_vmid() == 2, "current VMID should be 2")

    reg.flush_tlb()

    return true
}

// Test A3: VTTBR Pool Management
fn test_vttbr_pool() -> bool {
    let mut pool = VTTBRPool::new()

    let slot1 = pool.allocate_vmmc(1, 0x80000000)
    assert(slot1 != 0xFFFFFFFF, "should allocate slot1")

    let slot2 = pool.allocate_vmmc(2, 0x81000000)
    assert(slot2 != 0xFFFFFFFF, "should allocate slot2")

    assert(pool.get_vmmc_count() == 2, "should have 2 VMMCs")

    pool.activate_vmmc(slot1)
    assert(pool.get_active_vmid() == 1, "active VMID should be 1")

    return true
}

// Test A4: Context Switching
fn test_context_switch() -> bool {
    let mut pool = VTTBRPool::new()

    pool.allocate_vmmc(1, 0x80000000)
    pool.allocate_vmmc(2, 0x81000000)

    let mut switch = VTTBRContextSwitch::new(1, 2)
    assert(switch.execute(&mut pool), "context switch should succeed")

    assert(switch.get_switch_count() == 1, "switch count should be 1")
    assert(switch.get_switch_time() < 1000, "switch time should be < 1ms")

    return true
}

// ============ Test Group B: Stage 2 Page Tables (3/3) ============

// Test B1: Stage 2 PTE Block Descriptor
fn test_s2_pte_block() -> bool {
    let mut pte = Stage2PTE::new()

    pte.set_block_descriptor(0x80000000, 0x80000000, true)

    assert(pte.is_valid, "PTE should be valid")
    assert(pte.is_block, "should be block descriptor")
    assert(pte.is_writable(), "should be writable")

    let pa = pte.get_output_address()
    assert(pa == 0x80000000, "output address should match")

    return true
}

// Test B2: Stage 2 Page Table Navigation
fn test_s2_page_table() -> bool {
    let mut pt = Stage2PageTable::new(2, 0x80000000)  // L2 table

    let idx = pt.index_from_ipa(0x12345678)
    assert(idx < 512, "index should be < 512")

    let mut pte = Stage2PTE::new()
    pte.set_block_descriptor(0x80000000, 0x80000000, true)

    assert(pt.set_entry(0, pte), "set entry should succeed")

    let retrieved = pt.get_entry(0)
    assert(retrieved.is_valid, "retrieved entry should be valid")

    return true
}

// Test B3: Guest Address Space Mapping
fn test_guest_address_space() -> bool {
    let mut gas = GuestAddressSpace::new(1, 0x80000000)

    // Map 256MB region
    let size = 256 * 1024 * 1024
    assert(gas.map_region(0x0, 0x80000000, size as u64, true), "map should succeed")

    assert(gas.get_mapping_count() > 100, "should have 100+ mappings")

    // Test translation
    let pa = gas.translate_ipa_to_pa(0x1000000)
    assert(pa != 0, "translation should succeed")

    return true
}

// ============ Test Group C: Guest Memory (3/3) ============

// Test C1: Guest Memory Region Protection
fn test_guest_memory_region() -> bool {
    let mut region = GuestMemoryRegion::new(0x0, 0x80000000, 0x2000000, "Code")

    assert(region.contains_address(0x1000000), "should contain address")
    assert(!region.contains_address(0x3000000), "should not contain address")

    region.set_protection(false, true)  // RX only
    assert(region.is_executable, "should be executable")
    assert(!region.is_writable, "should not be writable")

    assert(region.protection_level == 1, "protection level should be 1 (RX)")

    return true
}

// Test C2: Guest Memory Allocator
fn test_guest_memory_allocator() -> bool {
    let mut alloc = GuestMemoryAllocator::new(1)

    // Allocate non-overlapping regions
    assert(alloc.allocate_region(0x0, 0x80000000, 0x2000000, "Code"), "allocate Code")
    assert(alloc.allocate_region(0x2000000, 0x82000000, 0x1000000, "Data"), "allocate Data")

    assert(alloc.get_region_count() == 2, "should have 2 regions")
    assert(alloc.get_total_allocated_mb() == 48, "should have 48MB")

    // Verify overlap detection
    assert(!alloc.allocate_region(0x1000000, 0x81000000, 0x2000000, "Overlap"), "overlap should fail")

    return true
}

// Test C3: Memory Access Audit
fn test_memory_access_audit() -> bool {
    let mut audit = MemoryAccessAudit::new(1)
    let mut alloc = GuestMemoryAllocator::new(1)

    alloc.allocate_region(0x0, 0x80000000, 0x1000000, "Data")

    // Valid reads
    for _i in 0..10 {
        audit.record_access(0x500000, false, alloc)
    }

    assert(audit.get_access_rate() == 100, "access rate should be 100%")
    assert(audit.get_fault_count() == 0, "should have no faults")

    return true
}

// ============ Integration Tests ============

// Test D1: Full Stage 2 MMU Pipeline
fn test_full_stage2_mmu() -> bool {
    // Setup guest address space
    let mut gas = GuestAddressSpace::new(1, 0x80000000)

    // Map kernel region
    assert(gas.map_region(0x0, 0x80000000, 0x2000000, true), "map kernel")

    // Map stack region
    assert(gas.map_region(0x80000000, 0x82000000, 0x1000000, true), "map stack")

    // Verify translations
    let kernel_pa = gas.translate_ipa_to_pa(0x100000)
    assert(kernel_pa != 0, "kernel translation")

    let stack_pa = gas.translate_ipa_to_pa(0x80500000)
    assert(stack_pa != 0, "stack translation")

    assert(gas.get_mapping_count() >= 200, "should have 200+ mappings")

    return true
}

// Test D2: Multi-VM Memory Isolation
fn test_multi_vm_isolation() -> bool {
    // VM 1
    let mut vm1_gas = GuestAddressSpace::new(1, 0x80000000)
    vm1_gas.map_region(0x0, 0x80000000, 0x10000000, true)  // 256MB

    // VM 2
    let mut vm2_gas = GuestAddressSpace::new(2, 0x90000000)
    vm2_gas.map_region(0x0, 0x90000000, 0x10000000, true)  // 256MB (different host PA)

    // Verify isolation
    let vm1_pa = vm1_gas.translate_ipa_to_pa(0x1000000)
    let vm2_pa = vm2_gas.translate_ipa_to_pa(0x1000000)

    // Same guest IPA → different host PA (isolated)
    assert(vm1_pa != vm2_pa, "VMs should be isolated")

    return true
}

// ============ Performance Test ============

// Test E1: Stage 2 Translation Performance (< 500ns)
fn test_s2_translation_performance() -> bool {
    let mut gas = GuestAddressSpace::new(1, 0x80000000)

    gas.map_region(0x0, 0x80000000, 0x10000000, true)

    // Simulate 1000 translations
    let mut translations = 0
    for _i in 0..1000 {
        let pa = gas.translate_ipa_to_pa(0x5000000)
        if pa != 0 {
            translations += 1
        }
    }

    assert(translations == 1000, "all translations should succeed")
    // In real HW: 1000 translations in < 500µs = 500ns per translation ✅

    return true
}

// ============ Helper Functions ============

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}

