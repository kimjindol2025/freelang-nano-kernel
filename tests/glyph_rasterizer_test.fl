// Glyph Rasterizer Tests: SDF → Bitmap Conversion (18 Unforgiving Tests)

module glyph_rasterizer_test

use glyph_rasterizer::{
    Bitmap, AntiAliasingFilter, SDFRasterizer, ScaledGlyph, GlyphRenderer
}

use sdf_engine::{
    DistanceField
}

use math::{
    FixedPoint
}

// ============ Test Group A: Bitmap (3/3) ============

// Test A1: Bitmap Creation and Properties
fn test_bitmap_creation() -> bool {
    let bitmap = Bitmap::new(128, 128)

    assert(bitmap.width == 128, "width 128")
    assert(bitmap.height == 128, "height 128")
    assert(bitmap.stride == 128, "stride 128")
    assert(bitmap.size() == 16384, "size 128×128")
    assert(bitmap.total_pixels() == 16384, "total pixels")

    return true
}

// Test A2: Pixel Operations
fn test_bitmap_pixel_ops() -> bool {
    let mut bitmap = Bitmap::new(64, 64)

    // Set and get corner pixels
    assert(bitmap.set_pixel(0, 0, 255), "set (0,0)=255")
    assert(bitmap.get_pixel(0, 0) == 255, "get (0,0)=255")

    assert(bitmap.set_pixel(32, 32, 128), "set (32,32)=128")
    assert(bitmap.get_pixel(32, 32) == 128, "get (32,32)=128")

    assert(bitmap.set_pixel(63, 63, 0), "set (63,63)=0")
    assert(bitmap.get_pixel(63, 63) == 0, "get (63,63)=0")

    return true
}

// Test A3: Boundary Conditions
fn test_bitmap_boundaries() -> bool {
    let mut bitmap = Bitmap::new(32, 32)

    // Out of bounds should fail
    assert(!bitmap.set_pixel(32, 32, 100), "set out of bounds fails")
    assert(!bitmap.set_pixel(50, 50, 100), "set far out fails")

    // Out of bounds get returns 0
    assert(bitmap.get_pixel(32, 32) == 0, "out of bounds = 0")

    // Clear should zero all pixels
    assert(bitmap.set_pixel(0, 0, 200), "set pixel")
    assert(bitmap.clear(), "clear bitmap")
    assert(bitmap.get_pixel(0, 0) == 0, "cleared pixel = 0")

    return true
}

// ============ Test Group B: Anti-Aliasing Filter (3/3) ============

// Test B1: Filter Quality Levels
fn test_aa_filter_quality() -> bool {
    let mut filter = AntiAliasingFilter::new()

    assert(filter.quality == 1, "default low (1)")

    assert(filter.set_quality(0), "set none")
    assert(filter.quality == 0, "quality 0")
    assert(filter.kernel_size == 1, "kernel 1×1")

    assert(filter.set_quality(1), "set low")
    assert(filter.quality == 1, "quality 1")
    assert(filter.kernel_size == 3, "kernel 3×3")

    assert(filter.set_quality(2), "set medium")
    assert(filter.quality == 2, "quality 2")
    assert(filter.kernel_size == 5, "kernel 5×5")

    assert(filter.set_quality(3), "set high")
    assert(filter.quality == 3, "quality 3")
    assert(filter.kernel_size == 7, "kernel 7×7")

    // Invalid quality
    assert(!filter.set_quality(4), "quality 4 fails")

    return true
}

// Test B2: Gaussian Dampening
fn test_aa_filter_gaussian() -> bool {
    let filter = AntiAliasingFilter::new()

    // No quality = pass through
    let val0 = filter.apply_gaussian(128)
    assert(val0 == 128, "quality 0 = pass through")

    return true
}

// Test B3: Pixel Blur Operation
fn test_aa_filter_blur() -> bool {
    let mut bitmap = Bitmap::new(16, 16)

    // Create a simple test pattern
    assert(bitmap.set_pixel(8, 8, 255), "set center")
    assert(bitmap.get_pixel(8, 8) == 255, "center = 255")

    let filter = AntiAliasingFilter::new()
    let blurred = filter.blur_pixel(&bitmap, 8, 8)

    assert(blurred > 0, "blurred value > 0")
    assert(blurred <= 255, "blurred value <= 255")

    return true
}

// ============ Test Group C: SDF Rasterizer (3/3) ============

// Test C1: Rasterizer Configuration
fn test_sdf_rasterizer_config() -> bool {
    let mut rasterizer = SDFRasterizer::new()

    assert(rasterizer.threshold == 0, "default threshold 0")
    assert(rasterizer.smoothness == 8, "default smoothness 8")

    assert(rasterizer.set_threshold(-5), "set threshold -5")
    assert(rasterizer.threshold == -5, "threshold -5")

    assert(rasterizer.set_smoothness(16), "set smoothness 16")
    assert(rasterizer.smoothness == 16, "smoothness 16")

    assert(rasterizer.set_aa_quality(2), "set AA medium")

    return true
}

// Test C2: Distance to Alpha Conversion
fn test_sdf_rasterizer_distance_to_alpha() -> bool {
    let rasterizer = SDFRasterizer::new()

    // Inside curve (negative distance)
    let alpha_inside = rasterizer.distance_to_alpha(-5)
    assert(alpha_inside == 255, "inside = opaque")

    // On curve (zero distance)
    let alpha_on = rasterizer.distance_to_alpha(0)
    assert(alpha_on > 100 && alpha_on < 255, "on curve = semi-transparent")

    // Outside curve (positive distance)
    let alpha_outside = rasterizer.distance_to_alpha(20)
    assert(alpha_outside < 100, "outside = transparent")

    // Far outside
    let alpha_far = rasterizer.distance_to_alpha(100)
    assert(alpha_far == 0, "far outside = fully transparent")

    return true
}

// Test C3: Rasterization Process
fn test_sdf_rasterizer_process() -> bool {
    let mut rasterizer = SDFRasterizer::new()
    let mut sdf = DistanceField::new(32, 32)

    // Create simple SDF pattern
    assert(sdf.set(0, 0, -10), "set center -10 (inside)")
    assert(sdf.set(0, 1, 10), "set edge +10 (outside)")

    assert(rasterizer.set_aa_quality(0), "no AA")

    let bitmap = rasterizer.rasterize(&sdf)
    assert(bitmap.width == 32, "bitmap width 32")
    assert(bitmap.height == 32, "bitmap height 32")

    return true
}

// ============ Test Group D: Scaled Glyph (3/3) ============

// Test D1: Scaled Glyph Creation
fn test_scaled_glyph_creation() -> bool {
    let scaled = ScaledGlyph::new(64, 128)

    assert(scaled.original_size == 64, "original size 64")
    assert(scaled.scaled_size == 128, "scaled size 128")

    let factor = scaled.get_scale_factor()
    assert(factor.raw > 0, "scale factor > 0")
    assert(factor.raw == 131072, "scale factor = 2.0")

    return true
}

// Test D2: Bitmap Scaling Operations
fn test_scaled_glyph_scaling() -> bool {
    let mut source = Bitmap::new(32, 32)
    assert(source.set_pixel(16, 16, 255), "set source")

    let mut scaled = ScaledGlyph::new(32, 64)
    assert(scaled.scale_bitmap(&source), "scale 2x")

    let bitmap = scaled.get_bitmap()
    assert(bitmap.width == 64, "result width 64")
    assert(bitmap.height == 64, "result height 64")

    return true
}

// Test D3: Various Scale Factors
fn test_scaled_glyph_factors() -> bool {
    // 0.5x scaling
    let scaled_half = ScaledGlyph::new(64, 32)
    let factor_half = scaled_half.get_scale_factor()
    assert(factor_half.raw == 32768, "0.5x = 0.5")

    // 1.0x scaling
    let scaled_one = ScaledGlyph::new(64, 64)
    let factor_one = scaled_one.get_scale_factor()
    assert(factor_one.raw == 65536, "1.0x = 1.0")

    // 2.0x scaling
    let scaled_two = ScaledGlyph::new(64, 128)
    let factor_two = scaled_two.get_scale_factor()
    assert(factor_two.raw == 131072, "2.0x = 2.0")

    // 4.0x scaling
    let scaled_four = ScaledGlyph::new(64, 256)
    let factor_four = scaled_four.get_scale_factor()
    assert(factor_four.raw == 262144, "4.0x = 4.0")

    return true
}

// ============ Test Group E: Glyph Renderer (3/3) ============

// Test E1: Renderer Creation and Configuration
fn test_glyph_renderer_config() -> bool {
    let mut renderer = GlyphRenderer::new()

    assert(renderer.set_quality(0), "set quality 0")
    assert(renderer.set_quality(3), "set quality 3")

    assert(renderer.quality_preset(0), "preset draft")
    assert(renderer.quality_preset(1), "preset screen")
    assert(renderer.quality_preset(2), "preset print")
    assert(renderer.quality_preset(3), "preset hq")

    assert(!renderer.quality_preset(4), "preset 4 fails")

    return true
}

// Test E2: Basic Rendering
fn test_glyph_renderer_render() -> bool {
    let mut renderer = GlyphRenderer::new()
    let mut sdf = DistanceField::new(32, 32)

    // Create SDF
    for y in 0..32 {
        for x in 0..32 {
            let dist = if (x > 8 && x < 24) && (y > 8 && y < 24) {
                -10  // Inside
            } else {
                10   // Outside
            }
            sdf.set(x, y, dist)
        }
    }

    assert(renderer.quality_preset(1), "set screen quality")
    let bitmap = renderer.render(&sdf)

    assert(bitmap.width == 32, "bitmap width 32")
    assert(bitmap.height == 32, "bitmap height 32")

    return true
}

// Test E3: Scaled Rendering
fn test_glyph_renderer_scaled() -> bool {
    let mut renderer = GlyphRenderer::new()
    let mut sdf = DistanceField::new(32, 32)

    // Create simple SDF
    for y in 0..32 {
        for x in 0..32 {
            sdf.set(x, y, 5)
        }
    }

    assert(renderer.quality_preset(0), "draft preset")

    let scaled = renderer.render_scaled(&sdf, 64)
    assert(scaled.original_size == 32, "original 32")
    assert(scaled.scaled_size == 64, "scaled 64")

    let bitmap = scaled.get_bitmap()
    assert(bitmap.width == 64, "result width 64")

    return true
}

// ============ Integration Tests ============

// Test F1: Complete Rendering Pipeline
fn test_complete_rendering_pipeline() -> bool {
    // Step 1: Create SDF field
    let mut sdf = DistanceField::new(64, 64)

    // Create circular pattern
    for y in 0..64 {
        for x in 0..64 {
            let cx = 32i32 - (x as i32)
            let cy = 32i32 - (y as i32)
            let dist_sq = cx * cx + cy * cy
            let dist = if dist_sq < 256 { -20 } else { 20 }
            sdf.set(x, y, dist)
        }
    }

    // Step 2: Create renderer
    let mut renderer = GlyphRenderer::new()
    assert(renderer.quality_preset(2), "print quality")

    // Step 3: Render
    let bitmap = renderer.render(&sdf)
    assert(bitmap.width == 64, "rendered width 64")
    assert(bitmap.height == 64, "rendered height 64")

    // Step 4: Verify pixels
    let center_alpha = bitmap.get_pixel(32, 32)
    assert(center_alpha == 255, "center = opaque")

    let edge_alpha = bitmap.get_pixel(48, 32)
    assert(edge_alpha > 0 && edge_alpha < 255, "edge = semi-transparent")

    return true
}

// Test F2: Multi-Scale Rendering
fn test_multi_scale_rendering() -> bool {
    let mut renderer = GlyphRenderer::new()
    let mut sdf = DistanceField::new(32, 32)

    // Simple SDF
    for y in 0..32 {
        for x in 0..32 {
            sdf.set(x, y, if x == y { 0 } else { 5 })
        }
    }

    // Render at multiple scales
    let scaled_half = renderer.render_scaled(&sdf, 16)
    assert(scaled_half.original_size == 32, "half: original 32")
    assert(scaled_half.scaled_size == 16, "half: scaled 16")

    let scaled_double = renderer.render_scaled(&sdf, 64)
    assert(scaled_double.original_size == 32, "double: original 32")
    assert(scaled_double.scaled_size == 64, "double: scaled 64")

    let scaled_quad = renderer.render_scaled(&sdf, 128)
    assert(scaled_quad.original_size == 32, "quad: original 32")
    assert(scaled_quad.scaled_size == 128, "quad: scaled 128")

    return true
}

// ============ Helper Functions ============

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}

