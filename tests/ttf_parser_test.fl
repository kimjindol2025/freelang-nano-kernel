// TTF Font Parser Tests (22 Unforgiving Tests)

module ttf_parser_test

use ttf_parser::{
    FontHeader, TableEntry, TableDirectory, CharacterMap, GlyphMetrics,
    GlyphData, TTFParser
}

use math::{
    FixedPoint, Vec2FP, QuadraticBezier
}

// ============ Test Group A: Font Header (3/3) ============

// Test A1: Font Header Creation
fn test_font_header_creation() -> bool {
    let mut header = FontHeader::new()

    assert(header.version == 0x00010000, "default version 1.0")
    assert(header.num_tables == 0, "initial tables 0")
    assert(!header.valid, "initially invalid")

    return true
}

// Test A2: Font Header Validation
fn test_font_header_validation() -> bool {
    let mut header = FontHeader::new()

    // Invalid: no tables
    assert(!header.validate(), "0 tables invalid")

    header.num_tables = 1
    assert(header.validate(), "1 table valid")

    header.num_tables = 15
    assert(header.validate(), "15 tables valid")

    header.num_tables = 21
    assert(!header.validate(), "21 tables invalid (> 20)")

    return true
}

// Test A3: Font Version Check
fn test_font_header_version() -> bool {
    let mut header = FontHeader::new()

    assert(header.version == 0x00010000, "TrueType 1.0")

    header.version = 0x00020000
    assert(!header.validate(), "version 2.0 invalid")

    header.version = 0x00010000
    header.num_tables = 5
    assert(header.validate(), "version 1.0 + 5 tables valid")

    return true
}

// ============ Test Group B: Table Directory (4/4) ============

// Test B1: Table Entry Creation
fn test_table_entry_creation() -> bool {
    let entry = TableEntry::new(0x68656164, 100, 54)  // "head"

    assert(entry.tag == 0x68656164, "tag 0x68656164")
    assert(entry.offset == 100, "offset 100")
    assert(entry.length == 54, "length 54")

    return true
}

// Test B2: Directory Add Tables
fn test_table_directory_add() -> bool {
    let mut dir = TableDirectory::new()

    assert(dir.count == 0, "initial count 0")

    let head = TableEntry::new(0x68656164, 0, 54)
    let cmap = TableEntry::new(0x636D6170, 100, 500)
    let loca = TableEntry::new(0x6C6F6361, 600, 200)

    assert(dir.add_table(head), "add head")
    assert(dir.count == 1, "count 1")

    assert(dir.add_table(cmap), "add cmap")
    assert(dir.count == 2, "count 2")

    assert(dir.add_table(loca), "add loca")
    assert(dir.count == 3, "count 3")

    return true
}

// Test B3: Find Table by Tag
fn test_table_directory_find() -> bool {
    let mut dir = TableDirectory::new()

    let head = TableEntry::new(0x68656164, 0, 54)
    let glyf = TableEntry::new(0x676C7966, 1000, 10000)

    assert(dir.add_table(head), "add head")
    assert(dir.add_table(glyf), "add glyf")

    let found_head = dir.find_table(0x68656164)
    assert(found_head.tag == 0x68656164, "find head")
    assert(found_head.offset == 0, "head offset 0")

    let found_glyf = dir.find_table(0x676C7966)
    assert(found_glyf.tag == 0x676C7966, "find glyf")
    assert(found_glyf.offset == 1000, "glyf offset 1000")

    return true
}

// Test B4: Directory Limits
fn test_table_directory_limits() -> bool {
    let mut dir = TableDirectory::new()

    // Add 20 tables (maximum)
    for i in 0..20 {
        let tag = 0x41414100 + (i as u32)
        let entry = TableEntry::new(tag, i as u32 * 100, 100)
        assert(dir.add_table(entry), "add table")
    }

    assert(dir.count == 20, "max 20 tables")

    // Try to add 21st (should fail)
    let entry21 = TableEntry::new(0x50505050, 2000, 100)
    assert(!dir.add_table(entry21), "21st table fails")

    return true
}

// ============ Test Group C: Character Map (3/3) ============

// Test C1: Character Map Creation
fn test_character_map_creation() -> bool {
    let cmap = CharacterMap::new()

    assert(cmap.glyph_count == 0, "initial count 0")

    return true
}

// Test C2: Add Unicode Mappings
fn test_character_map_add_mappings() -> bool {
    let mut cmap = CharacterMap::new()

    assert(cmap.add_mapping(65, 1), "map A (65) → 1")
    assert(cmap.add_mapping(66, 2), "map B (66) → 2")
    assert(cmap.add_mapping(67, 3), "map C (67) → 3")

    assert(cmap.glyph_count == 3, "count 3")

    assert(cmap.get_glyph_id(65) == 1, "A → 1")
    assert(cmap.get_glyph_id(66) == 2, "B → 2")
    assert(cmap.get_glyph_id(67) == 3, "C → 3")

    return true
}

// Test C3: Character Map Validation
fn test_character_map_validation() -> bool {
    let mut cmap = CharacterMap::new()

    assert(!cmap.validate(), "empty cmap invalid")

    assert(cmap.add_mapping(32, 0), "add space")
    assert(cmap.validate(), "cmap with 1 mapping valid")

    return true
}

// ============ Test Group D: Glyph Metrics (3/3) ============

// Test D1: Metrics Creation
fn test_glyph_metrics_creation() -> bool {
    let metrics = GlyphMetrics::new(1)

    assert(metrics.glyph_id == 1, "glyph_id 1")
    assert(metrics.advance_width == 0, "advance_width 0")
    assert(!metrics.is_valid(), "initially invalid")

    return true
}

// Test D2: Bounding Box Calculation
fn test_glyph_metrics_bbox() -> bool {
    let mut metrics = GlyphMetrics::new(1)

    metrics.advance_width = 100
    metrics.x_min = 10
    metrics.y_min = 0
    metrics.x_max = 90
    metrics.y_max = 70

    assert(metrics.is_valid(), "metrics valid")
    assert(metrics.bounding_box_width() == 80, "width 80")
    assert(metrics.bounding_box_height() == 70, "height 70")

    return true
}

// Test D3: Metrics Validation
fn test_glyph_metrics_validation() -> bool {
    let mut metrics = GlyphMetrics::new(2)

    assert(!metrics.is_valid(), "zero advance width invalid")

    metrics.advance_width = 50
    assert(metrics.is_valid(), "positive advance valid")

    return true
}

// ============ Test Group E: Glyph Data (3/3) ============

// Test E1: Glyph Creation
fn test_glyph_data_creation() -> bool {
    let glyph = GlyphData::new(5)

    assert(glyph.glyph_id == 5, "glyph_id 5")
    assert(glyph.curve_count == 0, "initial curves 0")
    assert(glyph.is_simple, "simple glyph")

    return true
}

// Test E2: Add Curves to Glyph
fn test_glyph_data_add_curves() -> bool {
    let mut glyph = GlyphData::new(10)

    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()
    let half = FixedPoint::HALF()

    let p0 = Vec2FP::new(zero, zero)
    let p1 = Vec2FP::new(half, one)
    let p2 = Vec2FP::new(one, zero)
    let curve1 = QuadraticBezier::new(p0, p1, p2)

    assert(glyph.add_curve(curve1), "add curve 1")
    assert(glyph.get_curve_count() == 1, "count 1")
    assert(glyph.outline_complexity() == 1, "complexity 1")

    let p0b = Vec2FP::new(one, zero)
    let p1b = Vec2FP::new(one, half)
    let p2b = Vec2FP::new(zero, one)
    let curve2 = QuadraticBezier::new(p0b, p1b, p2b)

    assert(glyph.add_curve(curve2), "add curve 2")
    assert(glyph.get_curve_count() == 2, "count 2")

    return true
}

// Test E3: Glyph Outline Complexity
fn test_glyph_data_complexity() -> bool {
    let mut glyph = GlyphData::new(15)

    let zero = FixedPoint::ZERO()
    let one = FixedPoint::ONE()

    for i in 0..10 {
        let offset = FixedPoint::from_int(i as i32).div(FixedPoint::from_int(10))

        let p0 = Vec2FP::new(zero, offset)
        let p1 = Vec2FP::new(one, offset)
        let p2 = Vec2FP::new(one, one)
        let curve = QuadraticBezier::new(p0, p1, p2)

        assert(glyph.add_curve(curve), "add curve")
    }

    assert(glyph.get_curve_count() == 10, "10 curves")
    assert(glyph.outline_complexity() == 10, "complexity 10")

    return true
}

// ============ Test Group F: TTF Parser (3/3) ============

// Test F1: Parser Creation
fn test_ttf_parser_creation() -> bool {
    let mut parser = TTFParser::new()

    assert(parser.header.version == 0x00010000, "default version")
    assert(parser.glyph_count == 0, "initial glyph count 0")
    assert(parser.units_per_em == 2048, "default units/em")

    return true
}

// Test F2: Parse Font Header
fn test_ttf_parser_header() -> bool {
    let mut parser = TTFParser::new()

    // Create a minimal header array
    let data = array[u8; 512]

    parser.header.num_tables = 10
    assert(parser.header.validate(), "header valid with 10 tables")

    let head_tag = TableEntry::new(0x68656164, 0, 54)
    assert(parser.add_table(head_tag.tag, head_tag.offset, head_tag.length), "add head table")

    assert(parser.directory.count == 1, "directory count 1")

    return true
}

// Test F3: Complete Font Parsing Pipeline
fn test_ttf_parser_pipeline() -> bool {
    let mut parser = TTFParser::new()

    // Setup header
    parser.header.num_tables = 4
    assert(parser.header.validate(), "header valid")

    // Add tables
    assert(parser.add_table(0x68656164, 0, 54), "add head")
    assert(parser.add_table(0x636D6170, 100, 500), "add cmap")
    assert(parser.add_table(0x676C7966, 1000, 10000), "add glyf")

    // Add character mappings
    assert(parser.add_glyph_mapping(65, 1), "map A → glyph 1")
    assert(parser.add_glyph_mapping(66, 2), "map B → glyph 2")

    // Load glyphs
    let metrics1 = GlyphMetrics::new(1)
    assert(parser.load_glyph(1, metrics1), "load glyph 1")

    let metrics2 = GlyphMetrics::new(2)
    assert(parser.load_glyph(2, metrics2), "load glyph 2")

    // Query
    assert(parser.character_to_glyph(65) == 1, "char A → 1")
    assert(parser.glyph_count == 2, "2 glyphs loaded")

    assert(parser.validate(), "parser valid")

    return true
}

// ============ Full Integration Test ============

// Test G1: Complete Font Lifecycle
fn test_complete_font_lifecycle() -> bool {
    let mut parser = TTFParser::new()

    // Phase 1: Setup
    parser.header.num_tables = 6
    assert(parser.header.validate(), "header setup")

    // Phase 2: Add tables
    assert(parser.add_table(0x68656164, 0, 54), "head")
    assert(parser.add_table(0x636D6170, 100, 1000), "cmap")
    assert(parser.add_table(0x6C6F6361, 1100, 400), "loca")
    assert(parser.add_table(0x676C7966, 1500, 8000), "glyf")

    // Phase 3: Create character map (A-Z)
    for i in 0..26 {
        let unicode = 65 + i  // 'A' = 65
        let glyph_id = (i + 1) as u16
        assert(parser.add_glyph_mapping(unicode as u32, glyph_id), "map char")
    }

    // Phase 4: Load glyphs
    for i in 1..27 {
        let mut metrics = GlyphMetrics::new(i)
        metrics.advance_width = 100 + (i as i16)
        metrics.x_min = 10
        metrics.y_min = 0
        metrics.x_max = 90
        metrics.y_max = 100
        assert(parser.load_glyph(i, metrics), "load glyph")
    }

    // Phase 5: Validate
    assert(parser.glyph_count == 26, "26 glyphs loaded")
    assert(parser.cmap.glyph_count == 26, "26 mappings")
    assert(parser.validate(), "font valid")

    // Phase 6: Query
    let a_glyph = parser.get_glyph_by_char(65)
    assert(a_glyph.glyph_id == 1, "char A → glyph 1")

    return true
}

// ============ Helper Functions ============

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}

